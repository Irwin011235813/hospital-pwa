rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNCIONES DE SEGURIDAD (El "candado") ---
    
    function isAuth() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuth() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- REGLAS POR COLECCIÓN ---

    // Colección de Usuarios: El usuario lee lo suyo, solo Admin ve todo
    match /users/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    // Colección de Noticias (Conexión Vecinal)
    match /noticias/{noticiaId} {
      allow read: if isAuth(); // Todos los vecinos logueados leen
      allow write: if isAdmin(); // Solo el CM/Admin publica o borra
    }

    // Colección de Turnos
    match /turnos/{turnoId} {
      // El vecino lee y crea su propio turno. El Admin gestiona todos.
      allow read, create: if isAuth(); 
      allow update, delete: if isAdmin();
    }

    // Colección de Vacunación a Domicilio (NUEVO)
    match /pedidos_vacuna/{pedidoId} {
      // El vecino pide su vacuna. Solo el Admin ve la lista para ir a las casas.
      allow create: if isAuth();
      allow read, update, delete: if isAdmin();
    }

    // Colección de Médicos/Cronograma
    match /especialistas/{espId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Colección de DEAs (Desfibriladores)
    match /dea_points/{deaId} {
      allow read: if isAuth(); // Cualquier vecino logueado puede ver los DEAs
      allow write: if isAdmin(); // Solo el Admin agrega/edita/borra
    }
  }
}
